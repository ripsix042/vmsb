# Server
NODE_ENV=development
PORT=5050
TRUST_PROXY=false

# MongoDB (e.g. mongodb://localhost:27017/kora-vms or Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/kora-vms

# JWT (use a long random string in production, 32+ chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
USE_HTTPONLY_COOKIE=false
ALLOW_PUBLIC_REGISTRATION=true

# CORS – comma-separated frontend origins (include Vite dev port if used)
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Email (Nodemailer) – your email address + password (or app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=

# Frontend URL (for links in emails)
FRONTEND_URL=http://localhost:8080

# Okta OIDC (SSO for Admin/Employee)
# Issuer URI from Okta Admin → Security → API → default (must include /oauth2/default), NOT the bare login URL
# Example: https://dev-12345.okta.com/oauth2/default  or  https://login.yourcompany.com/oauth2/default
OKTA_ISSUER=
# Only if your IdP issuer truly has no /oauth2/ path (rare)
# OKTA_RELAX_ISSUER_CHECK=false
# Single Okta app (use these OR the dual-app block below):
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
# Dual Okta apps (admin vs host): set BOTH client IDs and omit OKTA_CLIENT_ID (or leave unused).
# Register the same OKTA_REDIRECT_URI on each Okta application. Login: ?intent=admin | ?intent=host
OKTA_ADMIN_CLIENT_ID=
OKTA_ADMIN_CLIENT_SECRET=
OKTA_HOST_CLIENT_ID=
OKTA_HOST_CLIENT_SECRET=
# Must match the Redirect URI in Okta app settings:
# e.g. http://localhost:5050/api/v1/auth/okta/callback (local) or https://api-staging.yourdomain.com/api/v1/auth/okta/callback (staging)
OKTA_REDIRECT_URI=http://localhost:5050/api/v1/auth/okta/callback
OKTA_SCOPES=openid profile email
# Where to redirect after SSO success (frontend). Must match the SPA route below. If empty, API returns JSON instead of redirect.
OKTA_POST_LOGIN_REDIRECT=http://localhost:8080/auth/okta/callback
# Auto-create local user on first Okta login. Role follows login URL: intent=admin → Admin, intent=host → Employee.
OKTA_AUTO_PROVISION=false
# If true, existing users get role updated to match each login URL (admin vs host). Only if Okta app access is tightly controlled.
OKTA_SYNC_ROLE_FROM_INTENT=false
