# Server
NODE_ENV=development
PORT=5050
TRUST_PROXY=false

# MongoDB (e.g. mongodb://localhost:27017/kora-vms or Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/kora-vms

# JWT (use a long random string in production, 32+ chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
USE_HTTPONLY_COOKIE=false
ALLOW_PUBLIC_REGISTRATION=true

# CORS – comma-separated frontend origins
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer) – your email address + password (or app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=

# Frontend URL (for links in emails)
FRONTEND_URL=http://localhost:3000

# Okta OIDC (SSO for Admin/Employee)
# Example issuer: https://your-okta-domain.okta.com/oauth2/default
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
# Must match the Redirect URI in Okta app settings:
# e.g. http://localhost:5050/api/v1/auth/okta/callback (local) or https://api-staging.yourdomain.com/api/v1/auth/okta/callback (staging)
OKTA_REDIRECT_URI=http://localhost:5050/api/v1/auth/okta/callback
OKTA_SCOPES=openid profile email
# Where to redirect after SSO success (frontend). If empty, API returns JSON tokens instead of redirect.
OKTA_POST_LOGIN_REDIRECT=http://localhost:3000/auth/okta
# Auto-create local Employee records when Okta user not found (default false; recommended false in production)
OKTA_AUTO_PROVISION=false
