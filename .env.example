# Server
NODE_ENV=development
PORT=5050

# MongoDB (e.g. mongodb://localhost:27017/kora-vms or Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/kora-vms

# JWT (use a long random string in production, 32+ chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
USE_HTTPONLY_COOKIE=false

# CORS – comma-separated frontend origins
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer) – your email address + password (or app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=

# Frontend URL (for links in emails)
FRONTEND_URL=http://localhost:3000
