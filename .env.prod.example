# Production – copy to .env.prod and fill in real values.
# Use these SAME values in Render (or your host) Environment Variables.
# Never commit .env.prod (it's in .gitignore).

NODE_ENV=production
PORT=5050

# MongoDB Atlas (production cluster)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority

# JWT – use a long random string (32+ chars), different from staging
JWT_SECRET=generate-with-openssl-rand-hex-64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
USE_HTTPONLY_COOKIE=true

# Security – login lockout
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MS=900000

# Security – CSRF
CSRF_ENABLED=true
CSRF_HEADER_NAME=x-csrf-token

# Data retention (days)
RETENTION_DAYS_DEFAULT=365
INVITE_TTL_MINUTES=60
INVITE_REDIRECT_ALLOWLIST=https://your-app.com
QR_TOKEN_EXPIRES_MINUTES=480
REQUIRE_DB_TLS=true
PROD_DB_KEYWORDS=prod,production
ALLOW_NONPROD_PROD_DB=false

# Your production frontend URL(s), comma-separated if multiple
CORS_ORIGIN=https://your-app.com

# Email (production SMTP or provider)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# For links in emails (password reset, etc.)
FRONTEND_URL=https://your-app.com
